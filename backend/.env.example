# MongoDB Connection
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster0.3zq4ych.mongodb.net/myapp?retryWrites=true&w=majority&appName=Cluster0

# Server Configuration
PORT=5000
NODE_ENV=development

# ─── Uploads / Image Storage ────────────────────────────────────────────────
# Absolute path to the directory where uploaded images are stored.
# On Hostinger VPS: must match the nginx alias AND the SFTP remote dir so that
# ALL uploads (template previews + SFTP assets) are served from the same place.
# Example (VPS):  UPLOADS_DIR=/var/www/uploads
# Example (dev):  leave empty → defaults to backend/public/uploads/
# UPLOADS_DIR=/var/www/uploads

# Public-facing base URL of the backend (no trailing slash).
# Used to build absolute URLs in API responses (template upload-image endpoint).
# Leave empty in dev → relative paths are used (Vite proxy handles routing).
# On VPS: set to the domain that serves the Express backend.
# Example: PUBLIC_BASE_URL=https://yourvps.hostinger.com
# PUBLIC_BASE_URL=https://yourvps.hostinger.com

# Public frontend URL (used in CORS allow-list)
# Local example: http://localhost:5173
# Render example: https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# CORS
# Comma-separated list supported
# Local example: http://localhost:5173
# Render example: https://your-frontend.onrender.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Optional JWT settings
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# PostgreSQL (for authentication system)
# Option 1: full connection string
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/enterprise_saas
# Option 2: separate fields (used if POSTGRES_URL is empty)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_saas
POSTGRES_SSL=false

# SMTP (for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Hostinger SFTP for image uploads
# Leave SFTP_HOST empty to fall back to local disk storage (dev mode)
# SFTP_HOST=your.hostinger.server.com   # e.g. srv1234.hstgr.io
# SFTP_PORT=22
# SFTP_USERNAME=u123456789             # Hostinger FTP account username
# SFTP_PASSWORD=your_ftp_password
# SFTP_REMOTE_DIR=/public_html/uploads  # absolute path on remote host
# SFTP_PUBLIC_URL=https://yourdomain.com  # public base URL (no trailing slash)

# Auth tuning
OTP_EXPIRY_MINUTES=10
BCRYPT_ROUNDS=12

# ─── Redis (BullMQ bulk import queue) ──────────────────────────────────────
# Required for background CSV + ZIP import jobs.
# Run locally: docker run -d -p 6379:6379 redis:7-alpine
# Cloud: Upstash, Redis Cloud, or managed Redis.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password   # uncomment for authenticated Redis

# Worker concurrency — jobs processed simultaneously in one process
BULK_IMPORT_CONCURRENCY=3

# ─── Photo Processing Performance Tuning ───────────────────────────────────
# Number of BullMQ photo-processing jobs to run in parallel per worker process.
# Increase to match CPU cores: 8 is good for 4-core, 16 for 8-core servers.
# Rule of thumb: PHOTO_WORKER_CONCURRENCY = CPU_CORES * 2
PHOTO_WORKER_CONCURRENCY=8

# AI service URL (Python FastAPI on port 8001)
AI_SERVICE_URL=http://localhost:8001

# Number of uvicorn worker processes for the AI service.
# Set to CPU core count for production. Single process is fine for dev.
# AI_WORKERS=4

# Backend URL used by the AI service to fetch uploaded images.
# Must be reachable from the AI service process.
BACKEND_URL=http://localhost:5000
