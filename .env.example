# Frontend API base URL (backend Express server)
# Local dev: http://localhost:5000
# Render/VPS: https://your-backend.onrender.com  (or leave empty for same-origin)
VITE_API_BASE_URL=http://localhost:5000

# Base URL for /uploads/ assets (optional — for cross-origin deployments only).
# In dev the Vite proxy already forwards /uploads/* → http://localhost:5000.
# Leave empty (or omit) if frontend and backend are served from the SAME origin.
# Set to the backend's public origin when frontend and backend are on different domains.
# Example: VITE_UPLOADS_BASE_URL=https://api.yourvps.com
# VITE_UPLOADS_BASE_URL=
